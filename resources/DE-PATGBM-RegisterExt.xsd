  <xs:element name="dpma-patent-document">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="bibliographic-data" type="BibliographicDataType" />
        <xs:element name="events" type="EventsType" minOccurs="0"
          maxOccurs="1" />
      </xs:sequence>
      <xs:attribute name="schema-version" type="xs:string" />
    </xs:complexType>
  </xs:element>

  <xs:complexType name="AddressbookType">
    <xs:sequence>
      <xs:element name="text" type="xs:string" />
      <xs:element name="name" type="xs:string" />
      <xs:element name="address" type="AddressType" />
    </xs:sequence>
    <xs:attribute name="lang" type="xs:string" />
  </xs:complexType>

  <xs:complexType name="AddressType">
    <xs:sequence>
      <xs:element name="address-1" type="xs:string" minOccurs="0" />
      <xs:element name="country" type="xs:string" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AdditionType">
    <xs:annotation>
      <xs:documentation>
        <d:variablelist>
          <d:title>ZusatzanmeldungenAKZ</d:title>
          <d:varlistentry>
            <d:term>Patente (ZusatzanmeldungenAKZ):</d:term>
            <d:listitem>Referenz auf AKZ der Zusatzanmeldung; die
              Anmeldung ist
              die Hauptanmeldung und im DPMAregister werden
              0-n zu dieser
              Hauptanmeldung gemachte Zusatzanmeldungen referenziert.
            </d:listitem>
          </d:varlistentry>
        </d:variablelist>
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="relation" type="RelationType" minOccurs="0"
        maxOccurs="unbounded" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AgentsType">
    <xs:sequence>
      <xs:element name="agent" type="AgentType" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            <d:para>Daten zu den einzelnen Vertretern</d:para>
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AgentType">
    <xs:sequence>
      <xs:element name="addressbook" type="AddressbookType"
        maxOccurs="unbounded" />
    </xs:sequence>
    <xs:attribute name="sequence" type="xs:unsignedShort" />
  </xs:complexType>

  <xs:complexType name="ApplicantsType">
    <xs:sequence>
      <xs:element name="applicant" type="ApplicantType" maxOccurs="unbounded" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ApplicantType">
    <xs:annotation>
      <xs:documentation>
        <d:variablelist>
          <d:title>AnmelderInhaber</d:title>
          <d:varlistentry>
            <d:term>Patente (AnmelderInhaber):</d:term>
            <d:listitem>Name, Sitz und Länderkürzel (nach WIPO
              Standard ST.3) des
              aktuellen Anmelders;
              Details zur
              Anmelder Historie mit Datum der
              Rechtsübergänge sind in
              den Verfahrensständen
              ersichtlich
            </d:listitem>
          </d:varlistentry>
          <d:varlistentry>
            <d:term>Ergänzendes Schutzzertifikat (AnmelderInhaber):</d:term>
            <d:listitem>Name und vollständige Anschrift des aktuellen
              Anmelders;
              Details zur Anmelder
              Historie mit Datum der
              Rechtsübergänge sind in
              den Verfahrensständen ersichtlich;
              vollständige
              Anschrift ist für
              Schutzzertifikate durch das
              Gesetzt gefordert</d:listitem>
          </d:varlistentry>
          <d:varlistentry>
            <d:term>Gebrauchsmuster (AnmelderInhaber):</d:term>
            <d:listitem>Name, Sitz und Länderkürzel (nach WIPO
              Standard ST.3) des
              aktuellen Anmelders;
              Details zur
              Anmelder Historie mit Datum der
              Rechtsübergänge sind in
              den Verfahrensständen
              ersichtlich
            </d:listitem>
          </d:varlistentry>
          <d:varlistentry>
            <d:term>Topografien (Topografien - AnmelderInhaber):</d:term>
            <d:listitem>Name, Sitz und Länderkürzel (nach WIPO
              Standard ST.3) des
              aktuellen Anmelders;
              Details zur
              Anmelder Historie mit Datum der
              Rechtsübergänge sind in
              den Verfahrensständen
              ersichtlich
              Funktionale
              Anforderungen: [ID:13988] Recherchesystem /
              Expertensprache,
              [ID:14008] Suchfelder, [ID:14023] 24 Informationen
              zu
              Verfahren (AnmelderInhaber): Neuer
              Anmelder/Inhaber
						</d:listitem>
          </d:varlistentry>
        </d:variablelist>
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="addressbook" type="AddressbookType"
        maxOccurs="unbounded" />
    </xs:sequence>
    <xs:attribute name="sequence" type="xs:unsignedShort" />
    <xs:attribute name="app-type">
      <xs:simpleType>
        <xs:restriction base="xs:string">
          <xs:enumeration value="applicant" />
          <xs:enumeration value="applicant-inventor" />
        </xs:restriction>
      </xs:simpleType>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="ApplicationReferenceType">
    <xs:annotation>
      <xs:documentation>
        <d:variablelist>
          <d:title>Aktenzeichen</d:title>

          <d:varlistentry>
            <d:term>Patente (AktenzeichenDE):</d:term>
            <d:listitem>Nationales Aktenkennzeichen der Anmeldung.</d:listitem>
          </d:varlistentry>
          <d:varlistentry>
            <d:term>Patente (AktenzeichenEP):</d:term>
            <d:listitem>Aktenkennzeichen des Europäischen Patentamts
              für die
              Anmeldung; ist noch kein
              deutsches
              Aktenkennzeichen vergeben wird
              die Akte unter der
              Veröffentlichungsnummer und dem
              EP-Aktenzeichen
              geführt.
              Funktionale Anforderungen [ID:13988] Recherchesystem /
              Expertensprache [ID:14008] Suchfelder [ID:14023]
              7</d:listitem>
          </d:varlistentry>

          <d:varlistentry>
            <d:term>Patente (AktenzeichenWO):</d:term>
            <d:listitem>Internationales Aktenkennzeichen der WIPO für
              die
              Anmeldung; ist noch kein
              deutsches Aktenkennzeichen
              vergeben wird
              die Akte unter der Veröffentlichungsnummer
              und dem
              PCT-Aktenzeichen
              geführt.</d:listitem>
          </d:varlistentry>

          <d:varlistentry>
            <d:term>Ergänzendes Schutzzertifikat (AktenzeichenDE):</d:term>
            <d:listitem>Nationales Aktenkennzeichen des Schutzzertifikats
            </d:listitem>
          </d:varlistentry>

          <d:varlistentry>
            <d:term>Gebrauchsmuster (AktenzeichenDE):</d:term>
            <d:listitem>Nationales Aktenkennzeichen des
              Gebrauchsmuster
            </d:listitem>
          </d:varlistentry>

          <d:varlistentry>
            <d:term>Gebrauchsmuster (AktenzeichenEP):</d:term>
            <d:listitem>Referenz auf Aktenkennzeichen des Europäischen
              Patentamts, das mit dem
              Gebrauchmuster verknüpft
              ist.</d:listitem>
          </d:varlistentry>

          <d:varlistentry>
            <d:term>Gebrauchsmuster (AktenzeichenWO):</d:term>
            <d:listitem>Referenz auf internationales Aktenkennzeichen
              der WIPO,
              das mit dem Gebrauchsmuster
              verknüpft
              ist</d:listitem>
          </d:varlistentry>

          <d:varlistentry>
            <d:term>Topografien (Topografien - AktenzeichenDE):</d:term>
            <d:listitem>Nationales Aktenkennzeichen der Topografie</d:listitem>
          </d:varlistentry>
        </d:variablelist>
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="document-id" type="DocumentIdType" />
    </xs:sequence>
    <xs:attribute name="id" type="xs:ID" />
    <xs:attribute name="appl-type" type="xs:string" />
  </xs:complexType>

  <xs:complexType name="BibliographicDataType">
    <xs:sequence>
      <xs:element name="publication-references" type="PublicationReferencesType"
        minOccurs="0" />
      <xs:element name="application-reference" type="ApplicationReferenceType"
        minOccurs="1" maxOccurs="3" />
      <xs:element name="invention-title" type="InventionTitleType"
        minOccurs="0" maxOccurs="unbounded" />
      <xs:element name="classifications-ipcr" type="ClassificationsIpcrType"
        minOccurs="0" />
      <xs:element name="pct-or-regional-publishing-data" type="PctOrRegionalPublishingDataType"
        minOccurs="0" maxOccurs="3" />
      <xs:element name="pct-or-regional-filing-data" type="PctOrRegionalFilingDataType"
        minOccurs="0" maxOccurs="3" />
      <xs:element name="parties" type="PartiesType" minOccurs="0" />
      <xs:element name="references-cited" type="ReferencesCitedType"
        minOccurs="0" />
      <xs:element name="priority-claims" type="PriorityClaimsType"
        minOccurs="0" />
      <xs:element name="designation-of-states" type="DesignationOfStatesType"
        minOccurs="0" />
      <xs:element name="office-specific-bib-data" type="OfficeSpecificBibDataType" />
      <xs:element name="related-documents" type="RelatedDocumentsType"
        minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            <d:variablelist>
              <d:title>Abzweigungen</d:title>
              <d:varlistentry>
                <d:term>Gebrauchsmuster (AbzweigungAusAKZ):</d:term>
                <d:listitem> Referenz auf AKZ einer Patentanmeldung aus
                  der der
                  Anmeldetag beansprucht wird;
                  das zugehörige AKZ der
                  Patentanmeldung wird hier
                  referenziert.</d:listitem>
              </d:varlistentry>
              <d:varlistentry>
                <d:term>Patente (AbzweigungInAKZ):</d:term>
                <d:listitem>Referenz auf AKZ eines Gebrauchsmuster; zur
                  Anmeldung wurde ein
                  Gebrauchsmuster
                  abgezweigt; das zugehörige
                  AKZ des Gebrauchsmusters
                  wird hier referenziert; Details wie
                  Datum der Abzweigung sind den Verfahrensständen zu
                  entnehmen;
                  nicht für EPÜ-Patente
								</d:listitem>
              </d:varlistentry>
            </d:variablelist>
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="BoldType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element name="i" type="ItalicType" />
      <xs:element name="u" type="UnderscoreType" />
      <xs:element name="o" type="OverscoreType" />
      <xs:element name="smallcaps" type="SmallCapitalsType" />
      <xs:element name="sup" type="SuperscriptedType" />
      <xs:element name="sub" type="SubscriptedType" />
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="ClassificationsIpcrType">
    <xs:sequence>
      <xs:element name="classification-ipcr" type="ClassificationIpcrType"
        maxOccurs="unbounded" />
    </xs:sequence>
    <xs:attribute name="id" type="xs:ID" />
  </xs:complexType>

  <xs:complexType name="ClassificationIpcrType">
    <xs:sequence>
      <xs:element name="text" type="xs:string" />
      <xs:element name="ipc-version-indicator" type="xs:string" />
      <xs:element name="symbol-position" type="xs:string" minOccurs="0" />
    </xs:sequence>
    <xs:attribute name="sequence" type="xs:unsignedShort" />
  </xs:complexType>

  <xs:complexType name="ChildDocType">
    <xs:sequence>
      <xs:element name="document-id" type="DocumentIdType" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="CitationType">
    <xs:annotation>
      <xs:documentation>
        <d:variablelist>
          <d:title>Entgegenhaltungen</d:title>
          <d:varlistentry>
            <d:term>Patente (Entgegenhaltungen):</d:term>
            <d:listitem>Referenz auf 0-n ermittelte Entgegenhaltungen;
              dabei
              können die Entgegenhaltungen
              einerseits durch eine
              amtliche
              Recherche ermittelt oder in Einspruchsverfahren,
              Beschwerdeverfahren, etc. vorgebracht worden sein, handelt
